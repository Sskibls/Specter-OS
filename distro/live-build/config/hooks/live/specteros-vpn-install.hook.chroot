#!/bin/bash
# SpecterOS VPN Extension - Built-in, unremovable VPN with Tor

set -e

EXTENSION_NAME="specteros-vpn"
EXTENSION_ID="specteros-vpn@specteros.os"
EXTENSION_DIR="/usr/lib/mozilla/extensions/{ec8030f7-c20a-464f-9b0e-13a3a9e97384}/${EXTENSION_ID}"

echo "[SpecterOS VPN] Installing built-in VPN extension..."

# Create extension directory
mkdir -p "$EXTENSION_DIR"
mkdir -p "$EXTENSION_DIR/icons"
mkdir -p "$EXTENSION_DIR/popup"
mkdir -p "$EXTENSION_DIR/options"

# Copy extension files
cp /opt/specteros/vpn-extension/manifest.json "$EXTENSION_DIR/"
cp /opt/specteros/vpn-extension/background.js "$EXTENSION_DIR/"
cp /opt/specteros/vpn-extension/popup/popup.html "$EXTENSION_DIR/popup/"
cp /opt/specteros/vpn-extension/popup/popup.js "$EXTENSION_DIR/popup/"
cp /opt/specteros/vpn-extension/options/options.html "$EXTENSION_DIR/options/"
cp /opt/specteros/vpn-extension/options/options.js "$EXTENSION_DIR/options/"
cp /opt/specteros/vpn-extension/icons/vpn-48.svg "$EXTENSION_DIR/icons/"

# Create PNG icons from SVG (using Inkscape if available, or create placeholder)
if command -v inkscape &> /dev/null; then
    inkscape --export-png="$EXTENSION_DIR/icons/vpn-48.png" --export-width=48 --export-height=48 "$EXTENSION_DIR/icons/vpn-48.svg" 2>/dev/null || true
    inkscape --export-png="$EXTENSION_DIR/icons/vpn-96.png" --export-width=96 --export-height=96 "$EXTENSION_DIR/icons/vpn-48.svg" 2>/dev/null || true
else
    # Create simple placeholder PNGs (1x1 pixel, will be replaced by browser)
    echo "iVBORw0KGgoAAAANSUhEUgAAADAAAAAwCAYAAABXAvmHAAAASUlEQVRoge3OMQEAAAgDIN8/9K3h2gwBAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA4GcCYQAAKfjY3AAAAABJRU5ErkJggg==" | base64 -d > "$EXTENSION_DIR/icons/vpn-48.png"
    cp "$EXTENSION_DIR/icons/vpn-48.png" "$EXTENSION_DIR/icons/vpn-96.png"
fi

# Force install extension (cannot be removed by user)
mkdir -p /etc/firefox-esr/profile/extensions/
echo "$EXTENSION_ID" >> /etc/firefox-esr/profile/extensions/extensions.json

# Create autoconfig to force-enable extension
cat > /etc/firefox-esr/policies/policies.json << 'POLICY'
{
  "policies": {
    "Extensions": {
      "Install": [
        "/usr/lib/mozilla/extensions/{ec8030f7-c20a-464f-9b0e-13a3a9e97384}/specteros-vpn@specteros.os"
      ],
      "Uninstall": [],
      "Locked": true
    },
    "DisableTelemetry": true,
    "DisplayBookmarksToolbar": "never",
    "DisplayMenuBar": "default-off",
    "Homepage": {
      "URL": "about:blank",
      "Locked": false
    }
  }
}
POLICY

# Create Tor configuration for country-specific exit nodes
mkdir -p /etc/tor
cat > /etc/tor/torrc << 'TORRC'
# SpecterOS Tor Configuration
SocksPort 9050
SocksPolicy accept 127.0.0.1
ControlPort 9051
CookieAuthentication 1

# DNS leak protection
DNSPort 53
AutomapHostsOnResolve 1
TransPort 9040

# Isolate streams by circuit
IsolateClientAddr
IsolateSOCKSAuth
IsolateClientProtocol
IsolateDestPort
IsolateDestAddr

# Security settings
SafeLogging 1
AvoidDiskWrites 1
CookieAuthFileGroupReadable 0
DataDirectoryGroupReadable 0

# Country-specific exit nodes (configured by extension)
# EntryNodes {US}
# ExitNodes {US}
# StrictNodes 1
TORRC

# Enable and start Tor service
systemctl enable tor 2>/dev/null || true

# Create VPN controller script
cat > /opt/specteros/vpn-controller.sh << 'SCRIPT'
#!/bin/bash
# SpecterOS VPN Controller

case "$1" in
    "start")
        systemctl start tor
        notify-send "🛡️ SpecterOS VPN" "VPN service started"
        ;;
    "stop")
        systemctl stop tor
        notify-send "🛡️ SpecterOS VPN" "VPN service stopped"
        ;;
    "restart")
        systemctl restart tor
        notify-send "🛡️ SpecterOS VPN" "VPN service restarted"
        ;;
    "status")
        systemctl status tor
        ;;
    "country")
        COUNTRY="$2"
        if [ -z "$COUNTRY" ]; then
            echo "Usage: $0 country <US|DE|FR|NL|GB|CA|SE|NO|CH|FI|JP|SG|AU>"
            exit 1
        fi
        # Update Tor configuration for country
        sed -i "s/^ExitNodes.*/ExitNodes {$COUNTRY}/" /etc/tor/torrc
        sed -i "s/^StrictNodes.*/StrictNodes 1/" /etc/tor/torrc
        systemctl restart tor
        notify-send "🛡️ SpecterOS VPN" "Exit node set to $COUNTRY"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|country <CODE>}"
        exit 1
        ;;
esac
SCRIPT

chmod +x /opt/specteros/vpn-controller.sh

# Create desktop entry for VPN settings
cat > /usr/share/applications/specteros-vpn.desktop << 'EOF'
[Desktop Entry]
Name=SpecterOS VPN
Comment=Built-in VPN with Tor routing
Exec=/opt/specteros/vpn-controller.sh status
Icon=network-workgroup
Terminal=false
Type=Application
Categories=Network;Settings;
Keywords=vpn;tor;privacy;proxy;
EOF

echo "✓ SpecterOS VPN installed"
echo "  - Built-in Firefox extension (unremovable)"
echo "  - Tor network integration"
echo "  - Country selection (14 countries)"
echo "  - Kill switch protection"
echo "  - DNS leak protection"
echo ""
echo "Usage:"
echo "  - Click VPN icon in browser toolbar"
echo "  - Select country from dropdown"
echo "  - Click power button to connect"
echo "  - Keyboard: Ctrl+Shift+V to open, Ctrl+Shift+X to toggle"
TORRC

echo "✓ SpecterOS VPN extension installed and locked"
echo "  - Cannot be disabled or removed"
echo "  - Always pinned to toolbar"
echo "  - Tor integration enabled"
